        "test:bdd": "cucumber-js --import tests/support/hooks.js --import tests/steps/**/*.js tests/features/**/*.feature",
        "test:bdd:report": "mkdir -p reports && cucumber-js --format html:reports/cucumber.html --import tests/support/hooks.js --import tests/steps/**/*.js tests/features/**/*.feature"
    },
